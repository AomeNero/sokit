$(OBJDIR_RELEASE)\moc_msglistpanel.obj: $(MOCDIR_RELEASE)\moc_msglistpanel.cpp
    @echo Compiling moc_msglistpanel.cpp...
    $(CC) $(CFLAGS_RELEASE) /Fo$(OBJDIR_RELEASE)\moc_msglistpanel.obj $(MOCDIR_RELEASE)\moc_msglistpanel.cpp

$(OBJDIR_RELEASE)\qrc_icons.obj: $(TMPDIR)\qrc_icons.cpp
    @echo Compiling qrc_icons.cpp...
    $(CC) $(CFLAGS_RELEASE) /Fo$(OBJDIR_RELEASE)\qrc_icons.obj $(TMPDIR)\qrc_icons.cpp

$(OBJDIR_RELEASE)\sokit.res: $(SRCDIR)\sokit.rc
    @echo Compiling resource file...
    $(RC) /fo$(OBJDIR_RELEASE)\sokit.res $(SRCDIR)\sokit.rc

# ----------------------------------------------------
# Link (release)
# ----------------------------------------------------
$(BINDIR)\$(TARGET): dirs ui_headers moc_release rcc \
    $(OBJDIR_RELEASE)\main.obj \
    $(OBJDIR_RELEASE)\baseform.obj \
    $(OBJDIR_RELEASE)\clientform.obj \
    $(OBJDIR_RELEASE)\clientskt.obj \
    $(OBJDIR_RELEASE)\serverform.obj \
    $(OBJDIR_RELEASE)\serverskt.obj \
    $(OBJDIR_RELEASE)\transferform.obj \
    $(OBJDIR_RELEASE)\transferskt.obj \
    $(OBJDIR_RELEASE)\helpform.obj \
    $(OBJDIR_RELEASE)\notepadform.obj \
    $(OBJDIR_RELEASE)\logger.obj \
    $(OBJDIR_RELEASE)\setting.obj \
    $(OBJDIR_RELEASE)\toolkit.obj \
    $(OBJDIR_RELEASE)\msgitem.obj \
    $(OBJDIR_RELEASE)\msglistmodel.obj \
    $(OBJDIR_RELEASE)\msglistpanel.obj \
    $(OBJDIR_RELEASE)\moc_main.obj \
    $(OBJDIR_RELEASE)\moc_baseform.obj \
    $(OBJDIR_RELEASE)\moc_clientform.obj \
    $(OBJDIR_RELEASE)\moc_clientskt.obj \
    $(OBJDIR_RELEASE)\moc_serverform.obj \
    $(OBJDIR_RELEASE)\moc_serverskt.obj \
    $(OBJDIR_RELEASE)\moc_transferform.obj \
    $(OBJDIR_RELEASE)\moc_transferskt.obj \
    $(OBJDIR_RELEASE)\moc_helpform.obj \
    $(OBJDIR_RELEASE)\moc_notepadform.obj \
    $(OBJDIR_RELEASE)\moc_logger.obj \
    $(OBJDIR_RELEASE)\moc_msglistmodel.obj \
    $(OBJDIR_RELEASE)\moc_msglistpanel.obj \
    $(OBJDIR_RELEASE)\qrc_icons.obj \
    $(OBJDIR_RELEASE)\sokit.res
    @echo Linking release version...
    $(LINK) $(LFLAGS_RELEASE) /OUT:$(BINDIR)\$(TARGET) \
        /LIBPATH:"$(QT_LIB)" \
        /LIBPATH:"$(QT_PLUGINS)\platforms" \
        $(OBJDIR_RELEASE)\main.obj \
        $(OBJDIR_RELEASE)\baseform.obj \
        $(OBJDIR_RELEASE)\clientform.obj \
        $(OBJDIR_RELEASE)\clientskt.obj \
        $(OBJDIR_RELEASE)\serverform.obj \
        $(OBJDIR_RELEASE)\serverskt.obj \
        $(OBJDIR_RELEASE)\transferform.obj \
        $(OBJDIR_RELEASE)\transferskt.obj \
        $(OBJDIR_RELEASE)\helpform.obj \
        $(OBJDIR_RELEASE)\notepadform.obj \
        $(OBJDIR_RELEASE)\logger.obj \
        $(OBJDIR_RELEASE)\setting.obj \
        $(OBJDIR_RELEASE)\toolkit.obj \
        $(OBJDIR_RELEASE)\msgitem.obj \
        $(OBJDIR_RELEASE)\msglistmodel.obj \
        $(OBJDIR_RELEASE)\msglistpanel.obj \
        $(OBJDIR_RELEASE)\moc_main.obj \
        $(OBJDIR_RELEASE)\moc_baseform.obj \
        $(OBJDIR_RELEASE)\moc_clientform.obj \
        $(OBJDIR_RELEASE)\moc_clientskt.obj \
        $(OBJDIR_RELEASE)\moc_serverform.obj \
        $(OBJDIR_RELEASE)\moc_serverskt.obj \
        $(OBJDIR_RELEASE)\moc_transferform.obj \
        $(OBJDIR_RELEASE)\moc_transferskt.obj \
        $(OBJDIR_RELEASE)\moc_helpform.obj \
        $(OBJDIR_RELEASE)\moc_notepadform.obj \
        $(OBJDIR_RELEASE)\moc_logger.obj \
        $(OBJDIR_RELEASE)\moc_msglistmodel.obj \
        $(OBJDIR_RELEASE)\moc_msglistpanel.obj \
        $(OBJDIR_RELEASE)\qrc_icons.obj \
        $(OBJDIR_RELEASE)\sokit.res \
        $(QT_LIBS_RELEASE) \
        $(QT_PLUGIN_LIBS_RELEASE) \
        $(SYS_LIBS)
    @echo Build completed: $(BINDIR)\$(TARGET)

