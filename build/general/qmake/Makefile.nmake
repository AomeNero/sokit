    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_helpform.obj $(MOCDIR_DEBUG)\moc_helpform.cpp

$(OBJDIR_DEBUG)\moc_notepadform.obj: $(MOCDIR_DEBUG)\moc_notepadform.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_notepadform.obj $(MOCDIR_DEBUG)\moc_notepadform.cpp

$(OBJDIR_DEBUG)\moc_logger.obj: $(MOCDIR_DEBUG)\moc_logger.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_logger.obj $(MOCDIR_DEBUG)\moc_logger.cpp

$(OBJDIR_DEBUG)\moc_msglistmodel.obj: $(MOCDIR_DEBUG)\moc_msglistmodel.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_msglistmodel.obj $(MOCDIR_DEBUG)\moc_msglistmodel.cpp

$(OBJDIR_DEBUG)\moc_msglistpanel.obj: $(MOCDIR_DEBUG)\moc_msglistpanel.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_msglistpanel.obj $(MOCDIR_DEBUG)\moc_msglistpanel.cpp

$(OBJDIR_DEBUG)\qrc_icons.obj: $(TMPDIR)\qrc_icons.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\qrc_icons.obj $(TMPDIR)\qrc_icons.cpp

$(OBJDIR_DEBUG)\sokit.res: $(SRCDIR)\sokit.rc
    $(RC) /fo$(OBJDIR_DEBUG)\sokit.res $(SRCDIR)\sokit.rc

# ----------------------------------------------------
# Link (debug)
# ----------------------------------------------------
$(BINDIR)\debug\$(TARGET): dirs ui_headers moc_debug rcc \
    $(OBJDIR_DEBUG)\main.obj \
    $(OBJDIR_DEBUG)\baseform.obj \
    $(OBJDIR_DEBUG)\clientform.obj \
    $(OBJDIR_DEBUG)\clientskt.obj \
    $(OBJDIR_DEBUG)\serverform.obj \
    $(OBJDIR_DEBUG)\serverskt.obj \
    $(OBJDIR_DEBUG)\transferform.obj \
    $(OBJDIR_DEBUG)\transferskt.obj \
    $(OBJDIR_DEBUG)\helpform.obj \
    $(OBJDIR_DEBUG)\notepadform.obj \
    $(OBJDIR_DEBUG)\logger.obj \
    $(OBJDIR_DEBUG)\setting.obj \
    $(OBJDIR_DEBUG)\toolkit.obj \
    $(OBJDIR_DEBUG)\msgitem.obj \
    $(OBJDIR_DEBUG)\msglistmodel.obj \
    $(OBJDIR_DEBUG)\msglistpanel.obj \
    $(OBJDIR_DEBUG)\moc_main.obj \
    $(OBJDIR_DEBUG)\moc_baseform.obj \
    $(OBJDIR_DEBUG)\moc_clientform.obj \
    $(OBJDIR_DEBUG)\moc_clientskt.obj \
    $(OBJDIR_DEBUG)\moc_serverform.obj \
    $(OBJDIR_DEBUG)\moc_serverskt.obj \
    $(OBJDIR_DEBUG)\moc_transferform.obj \
    $(OBJDIR_DEBUG)\moc_transferskt.obj \
    $(OBJDIR_DEBUG)\moc_helpform.obj \
    $(OBJDIR_DEBUG)\moc_notepadform.obj \
    $(OBJDIR_DEBUG)\moc_logger.obj \
    $(OBJDIR_DEBUG)\moc_msglistmodel.obj \
    $(OBJDIR_DEBUG)\moc_msglistpanel.obj \
    $(OBJDIR_DEBUG)\qrc_icons.obj \
    $(OBJDIR_DEBUG)\sokit.res
    @echo Linking debug version...
    $(LINK) $(LFLAGS_DEBUG) /OUT:$(BINDIR)\debug\$(TARGET) /PDB:$(BINDIR)\debug\sokit.pdb \
        /LIBPATH:"$(QT_LIB)" \
        /LIBPATH:"$(QT_PLUGINS)\platforms" \
        $(OBJDIR_DEBUG)\main.obj \
        $(OBJDIR_DEBUG)\baseform.obj \
        $(OBJDIR_DEBUG)\clientform.obj \
        $(OBJDIR_DEBUG)\clientskt.obj \
        $(OBJDIR_DEBUG)\serverform.obj \
        $(OBJDIR_DEBUG)\serverskt.obj \
        $(OBJDIR_DEBUG)\transferform.obj \
        $(OBJDIR_DEBUG)\transferskt.obj \
        $(OBJDIR_DEBUG)\helpform.obj \
        $(OBJDIR_DEBUG)\notepadform.obj \
        $(OBJDIR_DEBUG)\logger.obj \
        $(OBJDIR_DEBUG)\setting.obj \
        $(OBJDIR_DEBUG)\toolkit.obj \
        $(OBJDIR_DEBUG)\msgitem.obj \
        $(OBJDIR_DEBUG)\msglistmodel.obj \
        $(OBJDIR_DEBUG)\msglistpanel.obj \
        $(OBJDIR_DEBUG)\moc_main.obj \
        $(OBJDIR_DEBUG)\moc_baseform.obj \
        $(OBJDIR_DEBUG)\moc_clientform.obj \
        $(OBJDIR_DEBUG)\moc_clientskt.obj \
        $(OBJDIR_DEBUG)\moc_serverform.obj \
        $(OBJDIR_DEBUG)\moc_serverskt.obj \
        $(OBJDIR_DEBUG)\moc_transferform.obj \
        $(OBJDIR_DEBUG)\moc_transferskt.obj \
        $(OBJDIR_DEBUG)\moc_helpform.obj \
        $(OBJDIR_DEBUG)\moc_notepadform.obj \
        $(OBJDIR_DEBUG)\moc_logger.obj \
        $(OBJDIR_DEBUG)\moc_msglistmodel.obj \
        $(OBJDIR_DEBUG)\moc_msglistpanel.obj \
        $(OBJDIR_DEBUG)\qrc_icons.obj \
        $(OBJDIR_DEBUG)\sokit.res \
        $(QT_LIBS_DEBUG) \
        $(QT_PLUGIN_LIBS_DEBUG) \
        $(SYS_LIBS)
    @echo Build completed: $(BINDIR)\debug\$(TARGET)

# ----------------------------------------------------
# Clean
# ----------------------------------------------------
clean:
    @echo Cleaning...
    @if exist "$(OBJDIR_RELEASE)" rmdir /s /q "$(OBJDIR_RELEASE)"
    @if exist "$(OBJDIR_DEBUG)" rmdir /s /q "$(OBJDIR_DEBUG)"
    @if exist "$(TMPDIR)\ui_*.h" del /q "$(TMPDIR)\ui_*.h" 2>nul
    @if exist "$(TMPDIR)\qrc_*.cpp" del /q "$(TMPDIR)\qrc_*.cpp" 2>nul
    @if exist "$(BINDIR)\$(TARGET)" del /q "$(BINDIR)\$(TARGET)" 2>nul
    @if exist "$(BINDIR)\debug\$(TARGET)" del /q "$(BINDIR)\debug\$(TARGET)" 2>nul
    @if exist "$(BINDIR)\debug\*.pdb" del /q "$(BINDIR)\debug\*.pdb" 2>nul
    @echo Clean completed.

# ----------------------------------------------------
# Translation update
# ----------------------------------------------------
translation:
    $(LUPDATE) $(SRCDIR) -ts $(SRCDIR)\sokit.ts
    $(LRELEASE) $(SRCDIR)\sokit.ts -qm $(BINDIR)\sokit.qm

# ----------------------------------------------------
# Show help
# ----------------------------------------------------
help:
    @echo sokit Makefile for nmake (MSVC + Qt5)
    @echo.
    @echo Usage:
    @echo   nmake          - Build release version
    @echo   nmake debug    - Build debug version
    @echo   nmake all      - Build both debug and release
    @echo   nmake clean    - Clean all generated files
    @echo   nmake translation - Update translation files
    @echo.
    @echo Configuration:
    @echo   QTDIR = $(QTDIR)
    @echo   If Qt is installed elsewhere, modify QTDIR at the top of Makefile.

.PHONY: all release debug clean dirs ui_headers moc_release moc_debug rcc translation help
