    $(CC) $(CFLAGS_RELEASE) /Fo$(OBJDIR_RELEASE)\moc_transferform.obj $(MOCDIR_RELEASE)\moc_transferform.cpp

$(OBJDIR_RELEASE)\moc_transferskt.obj: $(MOCDIR_RELEASE)\moc_transferskt.cpp
    @echo Compiling moc_transferskt.cpp...
