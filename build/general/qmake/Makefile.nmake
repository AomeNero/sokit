    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_clientskt.obj $(MOCDIR_DEBUG)\moc_clientskt.cpp

$(OBJDIR_DEBUG)\moc_serverform.obj: $(MOCDIR_DEBUG)\moc_serverform.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_serverform.obj $(MOCDIR_DEBUG)\moc_serverform.cpp

$(OBJDIR_DEBUG)\moc_serverskt.obj: $(MOCDIR_DEBUG)\moc_serverskt.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_serverskt.obj $(MOCDIR_DEBUG)\moc_serverskt.cpp

$(OBJDIR_DEBUG)\moc_transferform.obj: $(MOCDIR_DEBUG)\moc_transferform.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_transferform.obj $(MOCDIR_DEBUG)\moc_transferform.cpp

$(OBJDIR_DEBUG)\moc_transferskt.obj: $(MOCDIR_DEBUG)\moc_transferskt.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\moc_transferskt.obj $(MOCDIR_DEBUG)\moc_transferskt.cpp

