    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\notepadform.obj $(SRCDIR)\notepadform.cpp

$(OBJDIR_DEBUG)\logger.obj: $(SRCDIR)\logger.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\logger.obj $(SRCDIR)\logger.cpp

$(OBJDIR_DEBUG)\setting.obj: $(SRCDIR)\setting.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\setting.obj $(SRCDIR)\setting.cpp

$(OBJDIR_DEBUG)\toolkit.obj: $(SRCDIR)\toolkit.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\toolkit.obj $(SRCDIR)\toolkit.cpp

$(OBJDIR_DEBUG)\msgitem.obj: $(SRCDIR)\msgitem.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\msgitem.obj $(SRCDIR)\msgitem.cpp

$(OBJDIR_DEBUG)\msglistmodel.obj: $(SRCDIR)\msglistmodel.cpp
    $(CC) $(CFLAGS_DEBUG) /Fo$(OBJDIR_DEBUG)\msglistmodel.obj $(SRCDIR)\msglistmodel.cpp

